{
  "name": "@cctp-sdk/core",
  "version": "0.1.3",
  "description": "Production-grade CCTP v2 SDK — cross-chain USDC transfers in one function call",
  "keywords": ["cctp", "circle", "usdc", "cross-chain", "bridge", "viem", "ethereum", "arc"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Godbrand0/cctp_sdk.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "viem": ">=2.0.0"
  },
  "dependencies": {
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "viem": "^2.0.0",
    "vitest": "^1.0.0"
  }
}
